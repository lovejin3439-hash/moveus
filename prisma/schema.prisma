generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  CORPORATE
  ADMIN
}

enum MoveStatus {
  QUOTING
  CONTRACTED
  PACKED
  IN_TRANSIT
  ARRIVED
  DELIVERED
  CANCELLED
}

enum DocumentType {
  PASSPORT
  VISA
  INVENTORY
  OTHER
}

enum PaymentStatus {
  PENDING
  CHARGED
  SETTLED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          Role      @default(CUSTOMER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  moves         Move[]    @relation("CustomerMoves")
  vendor        Vendor?
  sessions      Session[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vendor {
  id            String   @id @default(cuid())
  userId        String   @unique
  companyName   String
  licenseNo     String?
  description   String?
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  badgeTier     String?
  serviceRoutes String[]
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  quotes   Quote[]
  moves    Move[]   @relation("VendorMoves")
  reviews  Review[]
}

model Move {
  id             String     @id @default(cuid())
  customerId     String
  vendorId       String?
  status         MoveStatus @default(QUOTING)
  origin         String
  destination    String
  estimatedCbm   Float      @default(0)
  finalCbm       Float?
  quotePrice     Float?
  packingDate    DateTime?
  deliveryDate   DateTime?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customer        User             @relation("CustomerMoves", fields: [customerId], references: [id])
  vendor          Vendor?          @relation("VendorMoves", fields: [vendorId], references: [id])
  items           Item[]
  quotes          Quote[]
  documents       Document[]
  contract        Contract?
  payment         Payment?
  trackingEvents  TrackingEvent[]
  review          Review?
}

model Item {
  id       String @id @default(cuid())
  moveId   String
  name     String
  category String
  size     String
  cbmValue Float
  quantity Int    @default(1)

  move Move @relation(fields: [moveId], references: [id], onDelete: Cascade)
}

model Quote {
  id            String   @id @default(cuid())
  moveId        String
  vendorId      String
  fclPrice      Float?
  lclPrice      Float?
  availableDates String[]
  appealPoints  String?
  companyIntro  String?
  submittedAt   DateTime @default(now())
  selected      Boolean  @default(false)

  move   Move   @relation(fields: [moveId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id])
}

model Document {
  id         String       @id @default(cuid())
  moveId     String
  type       DocumentType
  filename   String
  url        String
  status     String       @default("uploaded")
  uploadedAt DateTime     @default(now())

  move Move @relation(fields: [moveId], references: [id], onDelete: Cascade)
}

model Contract {
  id              String    @id @default(cuid())
  moveId          String    @unique
  signedAt        DateTime?
  eSignatureHash  String?
  agreedCbm       Float?
  agreedPrice     Float?
  createdAt       DateTime  @default(now())

  move Move @relation(fields: [moveId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String        @id @default(cuid())
  moveId      String        @unique
  amount      Float
  feeAmount   Float
  netAmount   Float
  status      PaymentStatus @default(PENDING)
  cardLast4   String?
  chargedAt   DateTime?
  settledAt   DateTime?
  receiptUrl  String?

  move Move @relation(fields: [moveId], references: [id], onDelete: Cascade)
}

model TrackingEvent {
  id        String   @id @default(cuid())
  moveId    String
  status    String
  location  String?
  note      String?
  timestamp DateTime @default(now())
  notified  Boolean  @default(false)

  move Move @relation(fields: [moveId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  moveId    String   @unique
  vendorId  String
  rating    Int
  comment   String?
  tags      String[]
  createdAt DateTime @default(now())

  move   Move   @relation(fields: [moveId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])
}
